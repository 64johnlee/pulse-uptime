# Copy to .env and adjust for your environment. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Postgres connection string used by the web app, worker, and migrations.
# Matches the credentials in docker-compose.yml for local development.
DATABASE_URL=postgres://pulse:pulse@localhost:5432/pulse

# Node environment (development | test | production)
NODE_ENV=development

# Web app public base URL (used for absolute links, status pages, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker tuning (check-runner)
WORKER_POLL_INTERVAL_MS=15000
# Port for the worker's liveness/readiness server (/healthz, /readyz).
WORKER_HEALTH_PORT=8080

# SSRF egress lock (worker). When unset/false, monitors may only probe public
# addresses — internal/link-local/metadata/RFC1918 targets are blocked. Set to
# true ONLY for self-hosted setups that intentionally monitor an internal
# network. See docs/adr/0004-worker-deploy.md.
# PULSE_ALLOW_PRIVATE_TARGETS=false
