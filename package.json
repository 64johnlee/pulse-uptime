{
  "name": "pulse",
  "version": "0.0.0",
  "private": true,
  "description": "Pulse — developer-first uptime monitoring and status pages",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "next": "15.5.19"
  },
  "scripts": {
    "dev": "pnpm --filter @pulse/web dev",
    "dev:worker": "pnpm --filter @pulse/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @pulse/db generate",
    "db:migrate": "pnpm --filter @pulse/db migrate",
    "db:seed": "pnpm --filter @pulse/db seed",
    "db:verify": "pnpm --filter @pulse/db verify"
  }
}
